# ── Database ──────────────────────────────────────────────
POSTGRES_USER=canteen
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hall_canteen
DATABASE_URL=postgresql+asyncpg://canteen:changeme@127.0.0.1:5440/hall_canteen

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6382/0

# ── Auth ──────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Firebase project id — required to verify Google (Firebase) ID tokens.
FIREBASE_PROJECT_ID=

# Redis-backed session cookie. In production (HTTPS, cross-site frontend) set
# SESSION_COOKIE_SECURE=true and SESSION_COOKIE_SAMESITE=none.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
# SESSION_TTL_SECONDS=604800
# SESSION_COOKIE_DOMAIN=

# Only these email domains may sign up / log in (apex + subdomains).
# JSON array; empty list [] disables the restriction.
ALLOWED_EMAIL_DOMAINS=["diu.edu.bd"]

# ── App ───────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# ── Object storage (Cloudflare R2, S3-compatible) ─────────
# Uploaded images (e.g. partner store photos) are stored in the bucket and only
# their public URL is saved in the database. Leave blank to keep images inline
# as base64 data URLs (handy for local dev / tests).
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL that serves the bucket (no trailing slash).
R2_PUBLIC_URL=
UPLOAD_MAX_FILE_SIZE_MB=10

# ── Docker port overrides (optional) ─────────────────────
# PG_HOST_PORT=5440
# REDIS_HOST_PORT=6382
# BACKEND_PORT=8000
